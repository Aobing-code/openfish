[Unit]
Description=FishRouter - AI Model Router
After=network.target

[Service]
Type=simple
User=fishrouter
Group=fishrouter
WorkingDirectory=/opt/fishrouter
ExecStart=/opt/fishrouter/venv/bin/python -m app.main
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
